{
  "name": "admin-boilerplate",
  "version": "0.0.1",
  "description": "Open-source admin-area boilerplate for SaaS-style projects on Cloudflare.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "dev:all": "pnpm exec concurrently -k -p \"[{name}]\" -n vite,worker -c \"cyan,magenta\" \"pnpm dev\" \"pnpm dev:worker\"",
    "build": "vite build",
    "preview": "wrangler dev --local",
    "deploy": "vite build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build",
    "migrate:local": "wrangler d1 migrations apply admin-boilerplate --local",
    "migrate:remote": "wrangler d1 migrations apply admin-boilerplate --remote"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20240924.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.78.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22"
  }
}
